{
  "name": "bluelist",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build --dotenv .env.local",
    "build:preview": "nuxt build --dotenv .env.preview",
    "build:production": "nuxt build --dotenv .env.production",
    "dev": "nuxt dev --dotenv .env.local",
    "generate": "nuxt generate --dotenv .env.local",
    "generate:preview": "nuxt generate --dotenv .env.preview",
    "generate:production": "nuxt generate --dotenv .env.production",
    "preview": "nuxt preview --dotenv .env.local",
    "preview:preview": "nuxt preview --dotenv .env.preview",
    "preview:production": "nuxt preview --dotenv .env.production",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "format": "prettier --write .",
    "prepare": "husky install"
  },
  "dependencies": {
    "@atproto/api": "^0.14.10",
    "@atproto/oauth-client-browser": "^0.3.16",
    "@nuxt/eslint": "1.2.0",
    "@nuxt/scripts": "0.11.2",
    "@nuxt/test-utils": "3.17.2",
    "@pinia/nuxt": "^0.11.0",
    "@unhead/vue": "^2.0.0-rc.8",
    "dompurify": "^3.2.4",
    "eslint": "^9.0.0",
    "nuxt": "^3.16.1",
    "openai": "^4.89.0",
    "pinia": "^3.0.2",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "eslint-config-prettier": "^10.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.0",
    "prettier": "^2.3.2",
    "typescript": "^5.8.2",
    "vue-tsc": "^2.2.8"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,scss,md,vue}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
